# Cloudflare Pages Redirects for Clodo Framework
# Enterprise SEO and user experience optimization
# Strategy: Force canonical domain (https://www.clodo.dev) and strip extensions

# DOMAIN CANONICALIZATION (Highest Priority)
# Redirect non-www to www with protocol normalization
http://* https://www.clodo.dev:splat 301
https://clodo.dev/* https://www.clodo.dev/:splat 301
http://clodo.dev/* https://www.clodo.dev/:splat 301
http://www.clodo.dev/* https://www.clodo.dev/:splat 301


# CONTENT REDIRECTS
# Redirect canonical aliases
/cloud-vs-edge /edge-vs-cloud-computing 301
# EXTENSION NORMALIZATION
# Strip .html extensions via explicit 301 redirects (SEO best practice)
# This ensures Google consolidates crawl budget and canonical signals
/*.html /:splat 301
/*/index.html /* 301
/*/index.amp.html /* 301
/index.amp.html / 301
/amp/* /amp/:splat 301
/blog/*.html /blog/:splat 301
/blog/index.amp.html /blog/ 301
/blog/*.amp.html /blog/:splat 301
/i18n/*/*.html /i18n/:splat 301
/i18n/*/index.html /i18n/:splat 301
/i18n/*.amp.html /i18n/:splat 301
/case-studies/*.html /case-studies/:splat 301
/case-studies/index.html /case-studies/ 301

# TRAILING SLASH NORMALIZATION
# Redirect trailing slashes to no-trailing-slash for consistency
/*/  /:splat 301

# STRATEGY NOTE:
# Cloudflare Pages serves both .html and extensionless URLs for the same content,
# but does NOT automatically redirect. This creates duplicate content issues for SEO.
# The explicit *.html -> extensionless redirects above consolidate to one canonical URL.
# This is intentional and necessary for proper SEO consolidation (no redirect loops occur).

