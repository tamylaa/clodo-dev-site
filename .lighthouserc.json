{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "node node_modules/http-server/bin/http-server dist -p 8080",
      "url": ["http://127.0.0.1:8080/"],
      "settings": {
        "chromeFlags": ["--no-sandbox", "--disable-gpu"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.60 }],
        "metrics:largest-contentful-paint": ["warn", { "maxNumericValue": 6000 }],
        "metrics:cumulative-layout-shift": ["warn", { "maxNumericValue": 0.25 }],
        "metrics:total-blocking-time": ["warn", { "maxNumericValue": 500 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "visual-tests/lighthouse-ci"
    }
  }
}
